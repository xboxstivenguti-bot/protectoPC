{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ANDER: Iniciar PC",
      "type": "shell",
      "command": "node ./start.js",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "ANDER: Detener PC",
      "type": "shell",
      "command": "docker compose down --remove-orphans",
      "problemMatcher": []
    },
    {
      "label": "GitHub: Traer cambios",
      "type": "shell",
      "command": "git pull --ff-only",
      "problemMatcher": []
    },
    {
      "label": "GitHub: Guardar cambios",
      "type": "shell",
      "command": "bash ./scripts/push-changes.sh",
      "problemMatcher": []
    },
    {
      "label": "ANDER: Ver contenedores",
      "type": "shell",
      "command": "docker compose ps",
      "problemMatcher": []
    },
    {
      "label": "ANDER: Ver logs",
      "type": "shell",
      "command": "docker compose logs -f --tail=150",
      "problemMatcher": []
    }
  ]
}
